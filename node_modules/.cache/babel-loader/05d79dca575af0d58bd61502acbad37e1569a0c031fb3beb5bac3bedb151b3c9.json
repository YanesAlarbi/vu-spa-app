.com/users.json\")\r\n        .then((response)=>{\r\n           return response.json();\r\n        }).then((data)=>{\r\n            const tmpArray=[];\r\n            for(let key in data)\r\n                {\r\n\r\n                    let withID=data[key];\r\n                    withID.ID=key;\r\n                    tmpArray.push(data[key]);\r\n                    \r\n                }\r\n\r\n                this.users=tmpArray;\r\n        });\r\n\r\n    },\r\n\r\n\r\n   },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.row{\r\n    margin-top: 8px;\r\n}\r\n</style>\r\n"],"mappings":";AA0BA;EACAA,KAAA;IACA;MAEAC,IAAA;QACAC,QAAA;QACAC,SAAA;QACAC,QAAA;MACA;MACAC,KAAA;IACA;EACA;EACAC,OAAA;IAEAC,UAAA,WAAAA,CAAA;MAEA,KAAAC,KAAA,CAAAC,GAAA,yEACAC,IAAA,CAAAC,QAAA;QACA,OAAAA,QAAA,CAAAC,IAAA;MACA,GAAAF,IAAA,CAAAV,IAAA;QACA,MAAAa,QAAA;QACA,SAAAC,GAAA,IAAAd,IAAA,EACA;UAEA,IAAAe,MAAA,GAAAf,IAAA,CAAAc,GAAA;UACAC,MAAA,CAAAC,EAAA,GAAAF,GAAA;UACAD,QAAA,CAAAI,IAAA,CAAAjB,IAAA,CAAAc,GAAA;QAEA;QAEA,KAAAT,KAAA,GAAAQ,QAAA;MACA;IAEA;EAGA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}