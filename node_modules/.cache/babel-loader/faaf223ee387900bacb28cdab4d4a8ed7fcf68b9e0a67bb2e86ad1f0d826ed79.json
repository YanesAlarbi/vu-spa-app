{"ast":null,"code":"export default {\n  name: \"AddUser\",\n  methods: {\n    postUser() {\n      this.$http.post(\"https://vujs-firebase-project-default-rtdb.firebaseio.com/users.json\", this.user).then(() => {\n        this.user.username = \"\";\n        this.user.firstname = \"\";\n        this.user.lastname = \"\";\n        this.$alert(\"a new user is added!\", \"operation successed\", \"success\");\n      }, error => {\n        console.log(error);\n      });\n    }\n  },\n  data() {\n    return {\n      user: {\n        username: \"\",\n        firstname: \"\",\n        lastname: \"\"\n      }\n    };\n  }\n};","map":{"version":3,"names":["name","methods","postUser","$http","post","user","then","username","firstname","lastname","$alert","error","console","log","data"],"sources":["src/views/AddUser.vue"],"sourcesContent":["\r\n\r\n<template>\r\n    \r\n    <div class=\"container\">\r\n        <div class=\"row\">\r\n            <div class=\"col-6 offset-2\">\r\n                <h1>Add User</h1>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <div class=\"row\">\r\n            <div class=\"col-6 offset-2\">\r\n                <div class=\"container\">\r\n                    <div class=\"row\">\r\n                        <div class=\"col-12\">\r\n\r\n                            <div class=\"form-group\">\r\n\r\n                                <label>USerName</label>\r\n                                <input type=\"text\" class=\"form-control\" v-model=\"user.username\"/>\r\n                            </div>\r\n\r\n                            <div class=\"form-group\">\r\n                                <label>first name</label>\r\n                                <input type=\"text\" class=\"form-control\" v-model=\"user.firstname\"/>\r\n                            </div>\r\n\r\n                              <div class=\"form-group\">\r\n                                <label>last name</label>\r\n                                <input type=\"text\" class=\"form-control\" v-model=\"user.lastname\"/>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n\r\n                <button class=\"btn btn-primary float-left\" style=\"margin-left:12px;\" @click=\"postUser()\">Add User</button>\r\n\r\n            </div>\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n\r\n\r\n<script>\r\n\r\n\r\nexport default {\r\n   name:\"AddUser\",\r\n   methods:{\r\n\r\n    postUser(){\r\n        this.$http.post(\"https://vujs-firebase-project-default-rtdb.firebaseio.com/users.json\",this.user)\r\n        .then(()=>{\r\n            this.user.username=\"\";\r\n            this.user.firstname=\"\";\r\n            this.user.lastname=\"\";\r\n            this.$alert(\"a new user is added!\",\"operation successed\",\"success\");\r\n\r\n        },(error)=>{\r\n            console.log(error);\r\n        }\r\n    );\r\n    },\r\n\r\n\r\n   },\r\n\r\n\r\n   data(){\r\n    return{\r\n        user:{\r\n            username:\"\",\r\n            firstname:\"\",\r\n            lastname:\"\",\r\n        },\r\n    };\r\n   },\r\n\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.row{\r\n    margin-top: 8px;\r\n}\r\n</style>\r\n"],"mappings":"AAkDA;EACAA,IAAA;EACAC,OAAA;IAEAC,SAAA;MACA,KAAAC,KAAA,CAAAC,IAAA,8EAAAC,IAAA,EACAC,IAAA;QACA,KAAAD,IAAA,CAAAE,QAAA;QACA,KAAAF,IAAA,CAAAG,SAAA;QACA,KAAAH,IAAA,CAAAI,QAAA;QACA,KAAAC,MAAA;MAEA,GAAAC,KAAA;QACAC,OAAA,CAAAC,GAAA,CAAAF,KAAA;MACA,CACA;IACA;EAGA;EAGAG,KAAA;IACA;MACAT,IAAA;QACAE,QAAA;QACAC,SAAA;QACAC,QAAA;MACA;IACA;EACA;AAEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}